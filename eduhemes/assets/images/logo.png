<!-- HTML da logo (rasm kerak emas) -->
<div class="logo-container">
    <div class="logo-icon">
        <i class="fas fa-graduation-cap"></i>
    </div>
    <div class="logo-text">
        <h1>EduHemis</h1>
        <p>Universitet portali</p>
    </div>
</div>

<style>
.logo-container {
    display: flex;
    align-items: center;
    gap: 15px;
}

.logo-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 30px;
    box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
}

.logo-text h1 {
    font-size: 24px;
    font-weight: 800;
    color: #1e293b;
    margin: 0;
}

.logo-text p {
    font-size: 12px;
    color: #64748b;
    margin: 0;
}
</style>